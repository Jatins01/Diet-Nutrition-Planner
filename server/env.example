# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/diet-planner
# Or use MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/diet-planner

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# ML Service
ML_API_URL=http://localhost:8000

# CORS
CORS_ORIGIN=http://localhost:5173

# Optional: Spoonacular API for accurate food image recognition (get key at https://spoonacular.com/food-api)
# SPOONACULAR_API_KEY=your_api_key_here


